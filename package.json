    "autoprefixer": "^10.4.16",
    "esbuild": "^0.28.0",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.32",
    "rollup": "^4.60.3",
    "tailwindcss": "^3.4.0",
    "vite": "^5.4.21",
    "vite-plugin-singlefile": "^2.3.3"
